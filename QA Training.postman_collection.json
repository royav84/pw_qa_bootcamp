    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(201)});\r",
              "\r",
              "const json = pm.response.json();\r",
              "pm.test(\"Response has a field called id\", function(){\r",
              "    pm.expect(json).to.have.property('id')});\r",
              "\r",
              "pm.test(\"name in the response equals Roi Avital\", function(){\r",
              "    pm.expect(json.name).to.eql('Roi Avital')})\r",
              "\r",
              "pm.collectionVariables.set(\"userId\", json.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
